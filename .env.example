# ---------------------------------------------------------------------------
# Supabase (utilisé UNIQUEMENT comme base PostgreSQL hébergée — pas d'auth email)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Server-only. NEVER expose to the client. Grants full DB access (bypasses RLS).
# C'est la seule clé Supabase réellement nécessaire (lecture/écriture serveur).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clé anon : plus utilisée (l'auth Supabase a été remplacée par un mot de passe
# admin). Laisser vide / l'omettre.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Connexion admin (par mot de passe, sans email)
# ---------------------------------------------------------------------------
# Les admins (voir ADMIN_EMAILS) se connectent avec leur email + ce mot de passe
# partagé. Choisissez une valeur longue et secrète.
ADMIN_PASSWORD=change-me-long-secret

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public base URL, used to build magic-link redirect targets.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of admin emails (lowercased). These get /admin access.
# NOT stored in the holders table.
ADMIN_EMAILS=enzo.barel@matera.eu

# Support / contact email shown to holders (also seeded into admin_settings).
SUPPORT_EMAIL=bspce-2026@matera.eu

# ---------------------------------------------------------------------------
# Rate limiting (Upstash Redis / Vercel KV REST API)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Optional: IP allowlist for /admin (comma-separated CIDRs or IPs). Empty = off.
# ---------------------------------------------------------------------------
ADMIN_IP_ALLOWLIST=

# ---------------------------------------------------------------------------
# Optional: Slack Incoming Webhook for real-time survey-response notifications.
# Empty = off. Create one at https://api.slack.com/messaging/webhooks
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
